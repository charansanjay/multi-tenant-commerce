{
  "name": "platform",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "sharp",
      "supabase",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:admin": "turbo dev --filter=@platform/admin",
    "dev:web": "turbo dev --filter=@platform/web",
    "dev:super-admin": "turbo dev --filter=@platform/super-admin",
    "build": "turbo build",
    "build:admin": "turbo build --filter=@platform/admin",
    "build:web": "turbo build --filter=@platform/web",
    "build:super-admin": "turbo build --filter=@platform/super-admin",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:admin": "turbo test --filter=@platform/admin",
    "test:web": "turbo test --filter=@platform/web",
    "test:super-admin": "turbo test --filter=@platform/super-admin",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "prepare": "husky",
    "db:start": "pnpm dlx supabase@latest start",
    "db:stop": "pnpm dlx supabase@latest stop",
    "db:reset": "pnpm dlx supabase@latest db reset",
    "db:status": "pnpm dlx supabase@latest status",
    "db:migrate": "pnpm dlx supabase@latest migration new",
    "db:push": "pnpm dlx supabase@latest db push",
    "db:types": "pnpm dlx supabase@latest gen types typescript --local > apps/admin/src/types/database.types.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  }
}
